# ========================
# gonErp Environment Variables
# Copy this file to .env and fill in real values:
#   cp .env.example .env
# ========================

# --- PostgreSQL ---
POSTGRES_DB=gonerp
POSTGRES_USER=gonerp
POSTGRES_PASSWORD=<strong-password>

# --- Spring Boot (API) ---
DB_URL=jdbc:postgresql://db:5432/gonerp
DB_USER=gonerp
DB_PASS=<strong-password>
JWT_SECRET=<generate-with: openssl rand -base64 32>
CORS_ORIGINS=https://yourdomain.com

# --- Docker images (used by CI/CD, leave defaults for local) ---
# API_IMAGE=ghcr.io/<owner>/gonerp-api:latest
# WEB_IMAGE=ghcr.io/<owner>/gonerp-web:latest
